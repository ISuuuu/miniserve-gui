{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "miniserve-gui",
  "version": "0.5.4",
  "identifier": "com.kim.miniserve-gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "miniserve-gui",
        "width": 1100,
        "height": 700,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": [
          "zh-CN"
        ]
      },
      "nsis": {
        "languages": [
          "SimpChinese"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBQUI3QTc0NTFGRjJDOEYKUldTUExQOVJkSHFycXVSaVd3OGMyakk2UWJRSzRrd1ZFWmYxQkgwTk5KNUdwSkNTUWt2R1dBZjIK",
      "endpoints": [
        "https://github.com/ISuuuu/miniserve-gui/releases/latest/download/latest.json"
      ]
    }
  }
}
