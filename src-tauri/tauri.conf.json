{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "miniserve-gui",
  "version": "0.1.0",
  "identifier": "com.zhang.miniserve-gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "miniserve-gui",
        "width": 900,
        "height": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
   "windows": {
      "wix": {
        "language": ["zh-CN"]
      },
      "nsis": {
      "languages": ["SimpChinese"]
    }
    }
}
